<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Indian Startup Funding Intelligence</title>
<meta name="description" content="Daily auto-refreshed Indian startup funding intelligence — {{ meta.total_rounds }} rounds tracked." />
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    darkMode: 'class',
    theme: {
      extend: {
        fontFamily: {
          sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
          mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
        },
        colors: {
          brand: {
            50:  '#f0fdf4', 100: '#dcfce7', 200: '#bbf7d0', 300: '#86efac',
            400: '#4ade80', 500: '#22c55e', 600: '#16a34a', 700: '#15803d',
            800: '#166534', 900: '#14532d',
          },
        },
        boxShadow: {
          card: '0 1px 2px rgba(0,0,0,0.04), 0 2px 8px rgba(0,0,0,0.04)',
        },
      },
    },
  };
</script>
<link rel="preconnect" href="https://rsms.me/" />
<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
<script src="https://cdn.jsdelivr.net/npm/echarts@5.5.1/dist/echarts.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"></script>
<style>
  html { font-family: Inter, system-ui, sans-serif; }
  [x-cloak] { display: none !important; }
  .chart-box { min-height: 320px; }
  .chart-tall { min-height: 380px; }
  .scrollbar-thin::-webkit-scrollbar { width: 6px; height: 6px; }
  .scrollbar-thin::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
  .dark .scrollbar-thin::-webkit-scrollbar-thumb { background: #475569; }
  @media print {
    header, .no-print, button, input[type="range"], input[type="date"], input[type="text"] { display: none !important; }
    body { background: #fff !important; color: #000 !important; }
    .chart-box, .chart-tall { page-break-inside: avoid; }
    section { break-inside: avoid; }
  }
</style>
</head>
<body class="bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 transition-colors"
      x-data="dashboard()" x-init="init()" x-cloak>

<!-- ========================= HEADER ========================= -->
<header class="sticky top-0 z-40 border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 py-3 flex items-center justify-between gap-4">
    <div class="flex items-center gap-3 min-w-0">
      <div class="h-9 w-9 rounded-xl bg-gradient-to-br from-brand-500 to-emerald-600 flex items-center justify-center text-white font-bold shadow-card shrink-0">IN</div>
      <div class="min-w-0">
        <h1 class="text-sm sm:text-base font-semibold truncate">Indian Startup Funding Intelligence</h1>
        <p class="text-xs text-slate-500 dark:text-slate-400 truncate">
          Updated {{ meta.generated_at }} · <span x-text="filteredRows.length"></span> of {{ meta.total_rounds }} rounds
        </p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <button @click="downloadCsv()"
              class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg border border-slate-200 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 no-print">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V4"/></svg>
        <span x-text="'Download CSV (' + filteredRows.length + ')'"></span>
      </button>
      <a href="https://github.com/ryrk1020/indian-funding-pipeline" target="_blank" rel="noopener"
         class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 text-sm rounded-lg border border-slate-200 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 no-print">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        Source
      </a>
      <button @click="toggleDark()" class="p-2 rounded-lg border border-slate-200 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800" :title="dark ? 'Light mode' : 'Dark mode'">
        <svg x-show="!dark" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        <svg x-show="dark" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m8.66-12.66l-.7.7M4.04 19.96l-.7.7M21 12h-1M4 12H3m16.66 7.66l-.7-.7M4.04 4.04l-.7-.7M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
      </button>
    </div>
  </div>
</header>

<main class="max-w-[1440px] mx-auto px-4 sm:px-6 py-5 space-y-5">

<!-- ========================= KPIs ========================= -->
<section class="grid grid-cols-2 md:grid-cols-4 gap-3">
  <template x-for="kpi in kpis" :key="kpi.label">
    <div class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-4 shadow-card">
      <div class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-400" x-text="kpi.label"></div>
      <div class="mt-1 text-2xl font-semibold" x-text="kpi.value"></div>
      <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5" x-text="kpi.hint"></div>
    </div>
  </template>
</section>

<!-- ========================= FILTERS ========================= -->
<section class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-4 shadow-card">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-sm font-semibold">Filters</h2>
    <button @click="resetFilters()" class="text-xs text-brand-600 dark:text-brand-400 hover:underline">Reset all</button>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <!-- Date range -->
    <div>
      <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">Announced from</label>
      <input type="date" x-model="filters.dateFrom"
             class="w-full px-3 py-1.5 text-sm rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-brand-500" />
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">Announced to</label>
      <input type="date" x-model="filters.dateTo"
             class="w-full px-3 py-1.5 text-sm rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-brand-500" />
    </div>

    <!-- Amount range -->
    <div>
      <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">
        Min funding: <span x-text="formatUsd(filters.minAmount)" class="text-brand-600 dark:text-brand-400 font-mono"></span>
      </label>
      <input type="range" min="0" :max="meta.max_amount_usd || 1000000" step="100000" x-model.number="filters.minAmount"
             class="w-full accent-brand-500" />
    </div>

    <!-- Confidence -->
    <div>
      <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">
        Min confidence: <span x-text="(filters.minConfidence * 100).toFixed(0) + '%'" class="text-brand-600 dark:text-brand-400 font-mono"></span>
      </label>
      <input type="range" min="0" max="1" step="0.05" x-model.number="filters.minConfidence"
             class="w-full accent-brand-500" />
    </div>
  </div>

  <!-- Stages -->
  <div class="mt-4">
    <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-2">Stages</label>
    <div class="flex flex-wrap gap-1.5">
      <template x-for="s in meta.stages_present" :key="s">
        <button type="button" @click="toggleSet(filters.stages, s)"
                :class="filters.stages.includes(s)
                  ? 'bg-brand-500 text-white border-brand-500'
                  : 'bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700 hover:border-brand-400'"
                class="px-2.5 py-1 text-xs rounded-full border transition-colors"
                x-text="prettyStage(s)"></button>
      </template>
    </div>
  </div>

  <!-- Sectors + investor search -->
  <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
    <div x-show="meta.sectors_present.length">
      <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-2">
        Sectors (<span x-text="filters.sectors.length || 'all'"></span>)
      </label>
      <div class="flex flex-wrap gap-1.5 max-h-24 overflow-y-auto scrollbar-thin">
        <template x-for="s in meta.sectors_present" :key="s">
          <button type="button" @click="toggleSet(filters.sectors, s)"
                  :class="filters.sectors.includes(s)
                    ? 'bg-brand-500 text-white border-brand-500'
                    : 'bg-slate-50 dark:bg-slate-800 border-slate-200 dark:border-slate-700 hover:border-brand-400'"
                  class="px-2.5 py-1 text-xs rounded-full border transition-colors"
                  x-text="s"></button>
        </template>
      </div>
    </div>
    <div x-show="!meta.sectors_present.length">
      <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-2">Sectors</label>
      <div class="text-xs text-slate-400 italic py-1">No sectors tagged yet</div>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-600 dark:text-slate-400 mb-1">Search (company, investor, summary)</label>
      <input type="text" x-model.debounce.300ms="filters.search" placeholder="e.g. 'IvyCap' or 'fintech'"
             class="w-full px-3 py-1.5 text-sm rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 focus:outline-none focus:ring-2 focus:ring-brand-500" />
    </div>
  </div>
</section>

<!-- ========================= EMPTY STATE ========================= -->
<div x-show="filteredRows.length === 0" class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-12 text-center shadow-card">
  <svg class="w-12 h-12 mx-auto text-slate-300 dark:text-slate-700" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
  <p class="mt-3 text-sm font-medium">No rounds match your filters</p>
  <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Try widening the date range, clearing sectors, or lowering the amount threshold.</p>
  <button @click="resetFilters()" class="mt-4 px-3 py-1.5 text-xs rounded-lg bg-brand-500 text-white hover:bg-brand-600">Reset filters</button>
</div>

<!-- ========================= CHARTS ========================= -->
<section x-show="filteredRows.length > 0" class="space-y-3">
  <!-- Timeline (full width) -->
  <div class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-4 shadow-card">
    <h2 class="text-sm font-semibold mb-2">Funding over time</h2>
    <div id="chart-timeline" class="chart-tall"></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
    <div class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-4 shadow-card">
      <h2 class="text-sm font-semibold mb-2">Stage distribution</h2>
      <div id="chart-stages" class="chart-box"></div>
    </div>
    <div class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-4 shadow-card">
      <h2 class="text-sm font-semibold mb-2">Top sectors</h2>
      <div id="chart-sectors" class="chart-box"></div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
    <div class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-4 shadow-card">
      <h2 class="text-sm font-semibold mb-2">Top investors</h2>
      <div id="chart-investors" class="chart-box"></div>
    </div>
    <div class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-4 shadow-card">
      <h2 class="text-sm font-semibold mb-2">Round size distribution</h2>
      <div id="chart-distribution" class="chart-box"></div>
    </div>
  </div>
</section>

<!-- ========================= TABLE ========================= -->
<section x-show="filteredRows.length > 0" class="rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-card overflow-hidden">
  <div class="flex items-center justify-between px-4 py-3 border-b border-slate-200 dark:border-slate-800">
    <h2 class="text-sm font-semibold">Rounds</h2>
    <div class="text-xs text-slate-500 dark:text-slate-400"><span x-text="filteredRows.length"></span> rows · click a row for details</div>
  </div>
  <div class="overflow-x-auto scrollbar-thin">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 dark:bg-slate-800/50 text-slate-600 dark:text-slate-400 text-xs uppercase tracking-wide">
        <tr>
          <template x-for="col in columns" :key="col.key">
            <th class="px-3 py-2.5 text-left font-medium cursor-pointer select-none hover:text-slate-900 dark:hover:text-slate-100 whitespace-nowrap"
                @click="setSort(col.key)">
              <span x-text="col.label"></span>
              <span class="ml-1" x-text="sortIndicator(col.key)"></span>
            </th>
          </template>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
        <template x-for="(row, idx) in paginatedRows" :key="row.company + row.announced_on + idx">
          <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 cursor-pointer" @click="selected = row">
            <td class="px-3 py-2.5 font-medium" x-text="row.company || '—'"></td>
            <td class="px-3 py-2.5"><span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full" :class="stageBadgeClass(row.stage_raw)" x-text="row.stage || '—'"></span></td>
            <td class="px-3 py-2.5 font-mono text-xs whitespace-nowrap" x-text="row.amount || '—'"></td>
            <td class="px-3 py-2.5 text-slate-600 dark:text-slate-400" x-text="row.sector || '—'"></td>
            <td class="px-3 py-2.5 text-slate-600 dark:text-slate-400 truncate max-w-[180px]" x-text="row.lead_investor || '—'"></td>
            <td class="px-3 py-2.5 font-mono text-xs text-slate-500 whitespace-nowrap" x-text="row.announced_on || '—'"></td>
            <td class="px-3 py-2.5">
              <div class="flex items-center gap-1.5">
                <div class="w-10 h-1.5 rounded-full bg-slate-200 dark:bg-slate-700 overflow-hidden">
                  <div class="h-full" :class="confBarClass(row.confidence)" :style="'width:' + (row.confidence * 100) + '%'"></div>
                </div>
                <span class="text-xs font-mono text-slate-500" x-text="(row.confidence * 100).toFixed(0) + '%'"></span>
              </div>
            </td>
          </tr>
        </template>
      </tbody>
    </table>
  </div>
  <div class="flex items-center justify-between px-4 py-3 border-t border-slate-200 dark:border-slate-800 text-xs text-slate-500">
    <div>Showing <span x-text="Math.min((page - 1) * pageSize + 1, filteredRows.length)"></span>–<span x-text="Math.min(page * pageSize, filteredRows.length)"></span> of <span x-text="filteredRows.length"></span></div>
    <div class="flex items-center gap-1">
      <button @click="page = Math.max(1, page - 1)" :disabled="page === 1" class="px-2 py-1 rounded border border-slate-200 dark:border-slate-700 disabled:opacity-40 hover:bg-slate-100 dark:hover:bg-slate-800">Prev</button>
      <span class="px-2">Page <span x-text="page"></span> / <span x-text="totalPages"></span></span>
      <button @click="page = Math.min(totalPages, page + 1)" :disabled="page === totalPages" class="px-2 py-1 rounded border border-slate-200 dark:border-slate-700 disabled:opacity-40 hover:bg-slate-100 dark:hover:bg-slate-800">Next</button>
    </div>
  </div>
</section>

<footer class="pt-2 pb-8 text-center text-xs text-slate-400 dark:text-slate-600">
  Indian Startup Funding Intelligence · scraped daily from public sources · built with Python, SQLite, OpenRouter, and ECharts.
</footer>

</main>

<!-- ========================= DRAWER (row details) ========================= -->
<div x-show="selected" x-cloak class="fixed inset-0 z-50" style="display:none">
  <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm"
       x-show="selected" x-transition.opacity @click="selected = null"></div>
  <aside class="absolute top-0 right-0 h-full w-full sm:w-[460px] bg-white dark:bg-slate-900 shadow-xl border-l border-slate-200 dark:border-slate-800 overflow-y-auto scrollbar-thin"
         x-show="selected"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="translate-x-full"
         x-transition:enter-end="translate-x-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="translate-x-0"
         x-transition:leave-end="translate-x-full">
    <div class="sticky top-0 bg-white/90 dark:bg-slate-900/90 backdrop-blur border-b border-slate-200 dark:border-slate-800 px-5 py-4 flex items-start justify-between gap-3">
      <div class="min-w-0">
        <h3 class="text-base font-semibold truncate" x-text="selected?.company"></h3>
        <div class="flex items-center gap-2 mt-1">
          <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full" :class="selected && stageBadgeClass(selected.stage_raw)" x-text="selected?.stage"></span>
          <span class="text-xs text-slate-500" x-text="selected?.announced_on"></span>
        </div>
      </div>
      <button @click="selected = null" class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <div class="p-5 space-y-5" x-show="selected">
      <div class="grid grid-cols-2 gap-3">
        <div class="rounded-lg bg-slate-50 dark:bg-slate-800/50 p-3">
          <div class="text-[10px] uppercase tracking-wide text-slate-500 font-medium">Amount</div>
          <div class="text-lg font-semibold font-mono mt-1" x-text="selected?.amount || '—'"></div>
        </div>
        <div class="rounded-lg bg-slate-50 dark:bg-slate-800/50 p-3">
          <div class="text-[10px] uppercase tracking-wide text-slate-500 font-medium">Confidence</div>
          <div class="text-lg font-semibold font-mono mt-1" x-text="selected ? (selected.confidence * 100).toFixed(0) + '%' : '—'"></div>
        </div>
      </div>

      <div x-show="selected?.sector">
        <div class="text-[10px] uppercase tracking-wide text-slate-500 font-medium mb-1">Sector</div>
        <div class="text-sm" x-text="selected?.sector"></div>
      </div>

      <div x-show="selected?.summary">
        <div class="text-[10px] uppercase tracking-wide text-slate-500 font-medium mb-1">Summary</div>
        <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed" x-text="selected?.summary"></p>
      </div>

      <div x-show="selected && selected.investors.length">
        <div class="text-[10px] uppercase tracking-wide text-slate-500 font-medium mb-2">Investors</div>
        <div class="flex flex-wrap gap-1.5">
          <template x-for="inv in selected?.investors || []" :key="inv">
            <span class="px-2 py-1 text-xs rounded-lg bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700"
                  :class="inv === selected.lead_investor ? 'ring-1 ring-brand-500 font-medium' : ''"
                  x-text="inv + (inv === selected.lead_investor ? ' (lead)' : '')"></span>
          </template>
        </div>
      </div>

      <div x-show="selected && selected.sources.length">
        <div class="text-[10px] uppercase tracking-wide text-slate-500 font-medium mb-2">Sources</div>
        <div class="space-y-1.5">
          <template x-for="src in selected?.sources || []" :key="src">
            <a :href="src" target="_blank" rel="noopener" class="block text-xs text-brand-600 dark:text-brand-400 hover:underline break-all" x-text="src"></a>
          </template>
        </div>
      </div>
    </div>
  </aside>
</div>

<script>
  const ROUNDS = {{ rounds_json | safe }};
  const META = {{ meta_json | safe }};
  const STAGE_ORDER = ["pre_seed","seed","pre_series_a","series_a","series_b","series_c","series_d","series_e_plus","bridge","debt","grant","ipo","acquisition","undisclosed"];

  const charts = {};

  function dashboard() {
    return {
      meta: META,
      rounds: ROUNDS,
      dark: (localStorage.getItem('funding-dark') ?? (window.matchMedia('(prefers-color-scheme: dark)').matches ? '1' : '0')) === '1',
      selected: null,
      page: 1,
      pageSize: 25,
      sort: { key: 'announced_on', dir: 'desc' },
      columns: [
        { key: 'company', label: 'Company' },
        { key: 'stage', label: 'Stage' },
        { key: 'amount', label: 'Amount' },
        { key: 'sector', label: 'Sector' },
        { key: 'lead_investor', label: 'Lead investor' },
        { key: 'announced_on', label: 'Announced' },
        { key: 'confidence', label: 'Confidence' },
      ],
      filters: {
        dateFrom: '', dateTo: '',
        stages: [], sectors: [], search: '',
        minAmount: 0, minConfidence: 0,
      },

      init() {
        if (this.dark) document.documentElement.classList.add('dark');
        this.$nextTick(() => {
          this.mountCharts();
          this.renderCharts();
        });
        this.$watch('filteredRows', () => { this.page = 1; this.renderCharts(); });
        this.$watch('dark', (v) => {
          localStorage.setItem('funding-dark', v ? '1' : '0');
          document.documentElement.classList.toggle('dark', v);
          this.remountCharts();
        });
        window.addEventListener('resize', () => Object.values(charts).forEach(c => c && c.resize()));
        window.addEventListener('keydown', (e) => { if (e.key === 'Escape') this.selected = null; });
      },

      toggleDark() { this.dark = !this.dark; },

      toggleSet(arr, v) {
        const i = arr.indexOf(v);
        if (i === -1) arr.push(v); else arr.splice(i, 1);
      },

      resetFilters() {
        this.filters.dateFrom = '';
        this.filters.dateTo = '';
        this.filters.stages = [];
        this.filters.sectors = [];
        this.filters.search = '';
        this.filters.minAmount = 0;
        this.filters.minConfidence = 0;
      },

      get filteredRows() {
        const q = (this.filters.search || '').toLowerCase().trim();
        const df = this.filters.dateFrom || null;
        const dt = this.filters.dateTo || null;
        const minAmt = this.filters.minAmount || 0;
        const minConf = this.filters.minConfidence || 0;
        const stages = this.filters.stages;
        const sectors = this.filters.sectors;

        return this.rounds.filter(r => {
          if (df && r.announced_on && r.announced_on < df) return false;
          if (dt && r.announced_on && r.announced_on > dt) return false;
          if (stages.length && !stages.includes(r.stage_raw)) return false;
          if (sectors.length && !sectors.includes(r.sector)) return false;
          if (minConf && r.confidence < minConf) return false;
          if (minAmt && (r.amount_usd || 0) < minAmt) return false;
          if (q) {
            const hay = (r.company + ' ' + (r.sector||'') + ' ' + (r.summary||'') + ' ' + (r.lead_investor||'') + ' ' + r.investors.join(' ')).toLowerCase();
            if (!hay.includes(q)) return false;
          }
          return true;
        });
      },

      get sortedRows() {
        const { key, dir } = this.sort;
        const mul = dir === 'asc' ? 1 : -1;
        return [...this.filteredRows].sort((a, b) => {
          let av = a[key], bv = b[key];
          if (key === 'amount') { av = a.amount_usd || 0; bv = b.amount_usd || 0; }
          if (av == null) av = '';
          if (bv == null) bv = '';
          if (typeof av === 'number' && typeof bv === 'number') return (av - bv) * mul;
          return String(av).localeCompare(String(bv)) * mul;
        });
      },

      get totalPages() { return Math.max(1, Math.ceil(this.filteredRows.length / this.pageSize)); },
      get paginatedRows() {
        const start = (this.page - 1) * this.pageSize;
        return this.sortedRows.slice(start, start + this.pageSize);
      },

      setSort(key) {
        if (this.sort.key === key) this.sort.dir = this.sort.dir === 'asc' ? 'desc' : 'asc';
        else this.sort = { key, dir: 'desc' };
      },
      sortIndicator(key) {
        if (this.sort.key !== key) return '';
        return this.sort.dir === 'asc' ? '↑' : '↓';
      },

      get kpis() {
        const rows = this.filteredRows;
        const total = rows.reduce((s, r) => s + (r.amount_usd || 0), 0);
        const withAmt = rows.filter(r => r.amount_usd);
        const avg = withAmt.length ? total / withAmt.length : 0;
        const stageCounts = {};
        rows.forEach(r => { if (r.stage_raw) stageCounts[r.stage_raw] = (stageCounts[r.stage_raw] || 0) + 1; });
        const topStage = Object.entries(stageCounts).sort((a,b) => b[1] - a[1])[0];
        return [
          { label: 'Total raised', value: this.formatUsd(total), hint: 'across filtered rounds' },
          { label: 'Rounds', value: rows.length.toLocaleString(), hint: `of ${this.meta.total_rounds} tracked` },
          { label: 'Avg round', value: this.formatUsd(avg), hint: `${withAmt.length} with disclosed amount` },
          { label: 'Top stage', value: topStage ? this.prettyStage(topStage[0]) : '—', hint: topStage ? `${topStage[1]} rounds` : '' },
        ];
      },

      formatUsd(v) {
        if (!v) return '$0';
        if (v >= 1e9) return '$' + (v / 1e9).toFixed(1) + 'B';
        if (v >= 1e6) return '$' + (v / 1e6).toFixed(1).replace(/\.0$/, '') + 'M';
        if (v >= 1e3) return '$' + (v / 1e3).toFixed(0) + 'K';
        return '$' + v.toFixed(0);
      },

      prettyStage(raw) {
        const map = {pre_seed:'Pre-Seed',seed:'Seed',pre_series_a:'Pre-Series A',series_a:'Series A',series_b:'Series B',series_c:'Series C',series_d:'Series D',series_e_plus:'Series E+',bridge:'Bridge',debt:'Debt',grant:'Grant',ipo:'IPO',acquisition:'Acquisition',undisclosed:'Undisclosed'};
        return map[raw] || raw;
      },

      stageBadgeClass(raw) {
        const p = {
          pre_seed:'bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300',
          seed:'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300',
          pre_series_a:'bg-lime-100 text-lime-700 dark:bg-lime-900/40 dark:text-lime-300',
          series_a:'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300',
          series_b:'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300',
          series_c:'bg-violet-100 text-violet-700 dark:bg-violet-900/40 dark:text-violet-300',
          series_d:'bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-300',
          series_e_plus:'bg-fuchsia-100 text-fuchsia-700 dark:bg-fuchsia-900/40 dark:text-fuchsia-300',
          bridge:'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300',
          debt:'bg-orange-100 text-orange-700 dark:bg-orange-900/40 dark:text-orange-300',
          grant:'bg-teal-100 text-teal-700 dark:bg-teal-900/40 dark:text-teal-300',
          ipo:'bg-rose-100 text-rose-700 dark:bg-rose-900/40 dark:text-rose-300',
          acquisition:'bg-pink-100 text-pink-700 dark:bg-pink-900/40 dark:text-pink-300',
        };
        return p[raw] || 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400';
      },

      confBarClass(c) {
        if (c >= 0.85) return 'bg-emerald-500';
        if (c >= 0.6)  return 'bg-amber-500';
        return 'bg-rose-500';
      },

      downloadCsv() {
        const rows = this.filteredRows;
        if (!rows.length) return;
        const cols = ['company','sector','stage','amount','amount_usd','announced_on','lead_investor','investors','sources','confidence','summary'];
        const esc = (v) => {
          if (v == null) return '';
          const s = Array.isArray(v) ? v.join(' | ') : String(v);
          return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
        };
        const lines = [cols.join(',')];
        rows.forEach(r => lines.push(cols.map(c => esc(r[c])).join(',')));
        const blob = new Blob([lines.join('\n')], { type: 'text/csv;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'funding_rounds_' + new Date().toISOString().slice(0,10) + '.csv';
        a.click();
        URL.revokeObjectURL(url);
      },

      mountCharts() {
        ['timeline','stages','sectors','investors','distribution'].forEach(id => {
          const el = document.getElementById('chart-' + id);
          if (el && !charts[id]) charts[id] = echarts.init(el, this.dark ? 'dark' : null, { renderer: 'canvas' });
        });
      },

      remountCharts() {
        Object.values(charts).forEach(c => c && c.dispose());
        for (const k in charts) delete charts[k];
        this.mountCharts();
        this.renderCharts();
      },

      renderCharts() {
        const rows = this.filteredRows;
        if (!rows.length) return;
        const axisCol = this.dark ? '#334155' : '#e2e8f0';
        const textCol = this.dark ? '#cbd5e1' : '#475569';
        const baseOpts = {
          textStyle: { fontFamily: 'Inter, sans-serif', color: textCol },
          tooltip: { backgroundColor: this.dark ? '#1e293b' : '#ffffff', borderColor: axisCol, textStyle: { color: textCol } },
          grid: { top: 30, right: 20, bottom: 40, left: 60, containLabel: true },
        };

        // ----- Timeline: monthly $ + count -----
        const byMonth = {};
        rows.forEach(r => {
          if (!r.announced_on) return;
          const k = r.announced_on.slice(0, 7);
          byMonth[k] = byMonth[k] || { usd: 0, count: 0 };
          byMonth[k].usd += r.amount_usd || 0;
          byMonth[k].count += 1;
        });
        const months = Object.keys(byMonth).sort();
        charts.timeline && charts.timeline.setOption({
          ...baseOpts,
          tooltip: { ...baseOpts.tooltip, trigger: 'axis' },
          legend: { data: ['Total raised', 'Round count'], textStyle: { color: textCol } },
          xAxis: { type: 'category', data: months, axisLine: { lineStyle: { color: axisCol } } },
          yAxis: [
            { type: 'value', name: 'USD', axisLabel: { formatter: (v) => this.formatUsd(v) }, splitLine: { lineStyle: { color: axisCol } } },
            { type: 'value', name: 'Count', splitLine: { show: false } },
          ],
          series: [
            { name: 'Total raised', type: 'bar', data: months.map(m => byMonth[m].usd), itemStyle: { color: '#22c55e', borderRadius: [4,4,0,0] } },
            { name: 'Round count', type: 'line', yAxisIndex: 1, data: months.map(m => byMonth[m].count), smooth: true, lineStyle: { color: '#6366f1', width: 2 }, symbol: 'circle', symbolSize: 6 },
          ],
        }, { notMerge: true });

        // ----- Stages donut -----
        const stageMap = {};
        rows.forEach(r => { if (r.stage_raw) stageMap[r.stage_raw] = (stageMap[r.stage_raw]||0) + 1; });
        const stageData = STAGE_ORDER.filter(s => stageMap[s]).map(s => ({ name: this.prettyStage(s), value: stageMap[s] }));
        const palette = ['#22c55e','#3b82f6','#8b5cf6','#f59e0b','#ef4444','#06b6d4','#ec4899','#84cc16','#f97316','#a855f7','#14b8a6','#eab308','#64748b'];
        charts.stages && charts.stages.setOption({
          ...baseOpts,
          tooltip: { ...baseOpts.tooltip, trigger: 'item', formatter: '{b}: {c} ({d}%)' },
          legend: { orient: 'vertical', right: 0, top: 'middle', textStyle: { color: textCol, fontSize: 11 } },
          series: [{ type: 'pie', radius: ['45%', '72%'], center: ['35%', '50%'], avoidLabelOverlap: true,
            itemStyle: { borderRadius: 6, borderColor: this.dark ? '#0f172a' : '#fff', borderWidth: 2 },
            label: { show: false }, data: stageData.map((d, i) => ({ ...d, itemStyle: { color: palette[i % palette.length] } })) }],
        }, { notMerge: true });

        // ----- Sectors bar -----
        const sectorMap = {};
        rows.forEach(r => { if (r.sector) sectorMap[r.sector] = (sectorMap[r.sector]||0) + (r.amount_usd || 0); });
        const sectors = Object.entries(sectorMap).sort((a,b) => b[1]-a[1]).slice(0, 10).reverse();
        charts.sectors && charts.sectors.setOption({
          ...baseOpts,
          tooltip: { ...baseOpts.tooltip, trigger: 'axis', axisPointer: { type: 'shadow' }, formatter: (p) => `${p[0].name}<br/>${this.formatUsd(p[0].value)}` },
          xAxis: { type: 'value', axisLabel: { formatter: (v) => this.formatUsd(v), color: textCol }, splitLine: { lineStyle: { color: axisCol } } },
          yAxis: { type: 'category', data: sectors.map(s => s[0]), axisLine: { lineStyle: { color: axisCol } }, axisLabel: { color: textCol, fontSize: 11 } },
          series: [{ type: 'bar', data: sectors.map(s => s[1]), itemStyle: { color: '#3b82f6', borderRadius: [0,4,4,0] }, barWidth: '60%' }],
        }, { notMerge: true });

        // ----- Investors bar -----
        const invMap = {};
        rows.forEach(r => r.investors.forEach(i => { invMap[i] = (invMap[i]||0) + 1; }));
        const invs = Object.entries(invMap).sort((a,b) => b[1]-a[1]).slice(0, 10).reverse();
        charts.investors && charts.investors.setOption({
          ...baseOpts,
          tooltip: { ...baseOpts.tooltip, trigger: 'axis', axisPointer: { type: 'shadow' } },
          xAxis: { type: 'value', axisLabel: { color: textCol }, splitLine: { lineStyle: { color: axisCol } }, minInterval: 1 },
          yAxis: { type: 'category', data: invs.map(s => s[0]), axisLine: { lineStyle: { color: axisCol } }, axisLabel: { color: textCol, fontSize: 11 } },
          series: [{ name: 'Deals', type: 'bar', data: invs.map(s => s[1]), itemStyle: { color: '#8b5cf6', borderRadius: [0,4,4,0] }, barWidth: '60%' }],
        }, { notMerge: true });

        // ----- Amount distribution histogram -----
        const buckets = [
          { label: '<$1M', min: 0, max: 1e6 },
          { label: '$1–5M', min: 1e6, max: 5e6 },
          { label: '$5–20M', min: 5e6, max: 20e6 },
          { label: '$20–50M', min: 20e6, max: 50e6 },
          { label: '$50–100M', min: 50e6, max: 100e6 },
          { label: '$100M+', min: 100e6, max: Infinity },
        ];
        const counts = buckets.map(b => rows.filter(r => r.amount_usd && r.amount_usd >= b.min && r.amount_usd < b.max).length);
        charts.distribution && charts.distribution.setOption({
          ...baseOpts,
          tooltip: { ...baseOpts.tooltip, trigger: 'axis', axisPointer: { type: 'shadow' } },
          xAxis: { type: 'category', data: buckets.map(b => b.label), axisLabel: { color: textCol, fontSize: 11 }, axisLine: { lineStyle: { color: axisCol } } },
          yAxis: { type: 'value', axisLabel: { color: textCol }, splitLine: { lineStyle: { color: axisCol } }, minInterval: 1 },
          series: [{ type: 'bar', data: counts, itemStyle: { color: '#f59e0b', borderRadius: [4,4,0,0] }, barWidth: '60%' }],
        }, { notMerge: true });
      },
    };
  }
</script>
</body>
</html>
