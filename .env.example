# Copy to .env and fill in. Never commit .env.

# --- OpenRouter (LLM enrichment) ---
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Free-tier models (pick one):
#   deepseek/deepseek-chat-v3-0324:free
#   meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENROUTER_REFERER=https://github.com/ryrk1020/funding-pipeline
OPENROUTER_APP_NAME=funding-pipeline

# --- Google Sheets export (optional) ---
# Path to service-account JSON file with Sheets + Drive scope
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SHEET_ID=

# --- Pipeline knobs ---
PIPELINE_DB_PATH=data/funding.db
PIPELINE_LOG_LEVEL=INFO
PIPELINE_REQUEST_TIMEOUT=30
PIPELINE_MAX_CONCURRENCY=4
PIPELINE_RATE_LIMIT_PER_HOST=1.0
PIPELINE_USER_AGENT=funding-pipeline/0.1 (+https://github.com/ryrk1020/funding-pipeline)
